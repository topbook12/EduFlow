rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getBatch(batchId) {
      return get(/databases/$(database)/documents/batches/$(batchId)).data;
    }

    function isBatchTeacher(batchId) {
      return isSignedIn() && getBatch(batchId).teacherId == request.auth.uid;
    }

    // 1. Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // 2. Batches collection
    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.teacherId == request.auth.uid || request.resource.data.teacherId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    // 3. Enrollments collection
    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && (
        request.resource.data.studentId == request.auth.uid || 
        isBatchTeacher(request.resource.data.batchId)
      );
      
      allow update: if isSignedIn() && (
        // Allow student to report payment or enroll themselves
        resource.data.studentId == request.auth.uid ||
        // Allow teacher of the batch to manage enrollment details
        isBatchTeacher(resource.data.batchId) ||
        isBatchTeacher(request.resource.data.batchId)
      );
      
      allow delete: if isSignedIn() && isBatchTeacher(resource.data.batchId);
    }

    // 4. Study Materials collection
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.teacherId == request.auth.uid || request.resource.data.teacherId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    // 5. Notices collection
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.teacherId == request.auth.uid || request.resource.data.teacherId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
    }

    // 6. Attendance collection
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 7. Exams collection
    match /exams/{examId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 8. Exam Results collection
    match /examResults/{resultId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
